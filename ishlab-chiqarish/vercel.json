{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/daily-report",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/monthly-employee-report",
      "schedule": "0 1 1 * *"
    },
    {
      "path": "/api/weekly-employee-report",
      "schedule": "0 1 * * 6"
    }
  ]
}
